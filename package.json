{
    "name": "macondo-checker",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "latest",
        "eslint": "^10.6.0",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "jiti": "^2.7.0",
        "prettier": "^3.9.1",
        "typescript-eslint": "^8.62.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@earendil-works/pi-coding-agent": "^0.80.2",
        "@slack/bolt": "^4.7.3",
        "e2b": "^2.31.0",
        "zod": "^4.4.3"
    },
    "scripts": {
        "check": "bunx tsc --noEmit",
        "dev": "bun run src/index.ts",
        "format": "prettier --write src package.json README.md todo.md eslint.config.ts agents.md tsconfig.json .prettierrc",
        "format:check": "prettier --check src package.json README.md todo.md eslint.config.ts agents.md tsconfig.json .prettierrc",
        "start": "bun run src/index.ts",
        "prepare": "husky"
    }
}
